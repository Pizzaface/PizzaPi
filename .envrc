# PizzaPi runner configuration
# Copy this file to .envrc.local and fill in your actual keys
# Then run: direnv allow

# Get your API key from ~/.pizzapi/config.json or the PizzaPi web UI
export PIZZAPI_API_KEY="${PIZZAPI_API_KEY:-}"

# LLM Provider API Keys
export OPENAI_API_KEY="${OPENAI_API_KEY:-}"
export ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY:-}"

# Source local overrides if present
[[ -f .envrc.local ]] && source .envrc.local
